# LLM для NSM
# local — Qwen на GPU/CPU (по умолчанию)
LLM_PROVIDER=local
LLM_MODEL_ID=Qwen/Qwen3.5-4B
LLM_DEVICE=auto

# OpenRouter — DeepSeek V4 Flash (переключите LLM_PROVIDER=openrouter)
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama на том же сервере
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=llama3.2
# LLM_JSON_MODE=false

# Legacy Groq
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.1-8b-instant

# StoryDiffusion (https://github.com/HVision-NKU/StoryDiffusion)
STORYDIFFUSION_MODEL_ID=SG161222/RealVisXL_V4.0
STORYDIFFUSION_STYLE=Photographic
STORYDIFFUSION_ID_LENGTH=3
STORYDIFFUSION_SA32=0.5
STORYDIFFUSION_SA64=0.5

# Pipeline (мин. 3 сцены для StoryDiffusion)
DEFAULT_SCENES=4
DEFAULT_CFG=7.5
DEFAULT_STEPS=30
IMAGE_SIZE=512
LAF_LAMBDA_CSA=0.4
LAF_MU_CCA=0.2
ENABLE_LAF=true
# UNet CCA выключен по умолчанию — без эталонных фото ломает лица
ENABLE_LAF_CCA=false
CIM_CLIP_MODEL_ID=openai/clip-vit-large-patch14
CIM_DEVICE=auto
OUTPUT_DIR=outputs
