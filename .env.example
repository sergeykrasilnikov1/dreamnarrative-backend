# LLM для NSM (без VPN на сервере — используйте local)
LLM_PROVIDER=local
LLM_MODEL_ID=Qwen/Qwen3.5-4B

# Альтернатива: Ollama на том же сервере
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=llama3.2
# LLM_JSON_MODE=false

# Legacy Groq (нужен VPN)
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.1-8b-instant

# Pipeline
DEFAULT_SCENES=4
DEFAULT_CFG=7.5
DEFAULT_STEPS=30
IMAGE_SIZE=512
LAF_LAMBDA_CSA=0.4
LAF_MU_CCA=0.6
OUTPUT_DIR=outputs
